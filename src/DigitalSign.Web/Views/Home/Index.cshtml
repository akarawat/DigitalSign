@{
    ViewData["Title"] = "Home";
    var health = ViewBag.Health as DigitalSign.Web.Models.CertificateHealth;
}

<div class="row g-4">
    <div class="col-12">
        <h2 class="fw-bold"><i class="bi bi-pen"></i> BT Digital Sign</h2>
        <p class="text-muted">Digital Signature System for Bernina Thailand Internal Documents</p>
    </div>

    <!-- Certificate Status -->
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle p-2 me-3
                        @(health?.Status == "healthy" ? "bg-success" : "bg-danger") bg-opacity-10">
                        <i class="bi bi-shield-check fs-4
                            @(health?.Status == "healthy" ? "text-success" : "text-danger")"></i>
                    </div>
                    <div>
                        <h6 class="mb-0">Certificate Status</h6>
                        <span class="badge @(health?.Status == "healthy" ? "bg-success" : "bg-danger")">
                            @(health?.Status ?? "Unable to connect")
                        </span>
                    </div>
                </div>
                @if (health != null)
                {
                    <small class="text-muted">
                        Expires: @health.Expiry.ToString("dd/MM/yyyy")<br />
                        Remaining: @health.DaysRemaining days
                    </small>
                }
            </div>
        </div>
    </div>

    <!-- Quick Menu -->
    <div class="col-md-4">
        <a href="/Sign" class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm card-hover">
                <div class="card-body text-center py-4">
                    <i class="bi bi-pen-fill fs-1 text-primary mb-3 d-block"></i>
                    <h5 class="fw-semibold">Sign Data</h5>
                    <p class="text-muted small mb-0">Apply digital signature to text or data</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a href="/Sign/PdfSign" class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm card-hover">
                <div class="card-body text-center py-4">
                    <i class="bi bi-file-earmark-pdf-fill fs-1 text-danger mb-3 d-block"></i>
                    <h5 class="fw-semibold">Sign PDF</h5>
                    <p class="text-muted small mb-0">Apply digital signature to PDF documents</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a href="/Sign/Verify" class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm card-hover">
                <div class="card-body text-center py-4">
                    <i class="bi bi-patch-check-fill fs-1 text-success mb-3 d-block"></i>
                    <h5 class="fw-semibold">Verify Signature</h5>
                    <p class="text-muted small mb-0">Verify the authenticity of a digital signature</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a href="/Sign/Audit" class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm card-hover">
                <div class="card-body text-center py-4">
                    <i class="bi bi-clock-history fs-1 text-warning mb-3 d-block"></i>
                    <h5 class="fw-semibold">Sign History</h5>
                    <p class="text-muted small mb-0">View all digital signature records</p>
                </div>
            </div>
        </a>
    </div>

    <!-- User info -->
    <div class="col-12">
        <div class="alert alert-info mb-0">
            <i class="bi bi-person-circle"></i>
            Logged in as <strong>@ViewBag.User</strong> — Windows SSO authenticated
        </div>
    </div>
</div>
