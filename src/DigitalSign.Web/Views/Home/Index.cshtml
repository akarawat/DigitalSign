@{
    ViewData["Title"] = "หน้าหลัก";
    var health = ViewBag.Health as DigitalSign.Web.Models.CertificateHealth;
}

<div class="row g-4">
    <div class="col-12">
        <h2 class="fw-bold"><i class="bi bi-pen"></i> BT Digital Sign</h2>
        <p class="text-muted">ระบบลงลายเซ็นดิจิทัลสำหรับเอกสารภายใน Bernina Thailand</p>
    </div>

    <!-- สถานะระบบ -->
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle p-2 me-3
                        @(health?.Status == "healthy" ? "bg-success" : "bg-danger") bg-opacity-10">
                        <i class="bi bi-shield-check fs-4
                            @(health?.Status == "healthy" ? "text-success" : "text-danger")"></i>
                    </div>
                    <div>
                        <h6 class="mb-0">สถานะ Certificate</h6>
                        <span class="badge @(health?.Status == "healthy" ? "bg-success" : "bg-danger")">
                            @(health?.Status ?? "ไม่สามารถเชื่อมต่อได้")
                        </span>
                    </div>
                </div>
                @if (health != null)
                {
                    <small class="text-muted">
                        หมดอายุ: @health.Expiry.ToString("dd/MM/yyyy")<br />
                        เหลืออีก: @health.DaysRemaining วัน
                    </small>
                }
            </div>
        </div>
    </div>

    <!-- เมนูลัด -->
    <div class="col-md-4">
        <a href="/Sign" class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm card-hover">
                <div class="card-body text-center py-4">
                    <i class="bi bi-pen-fill fs-1 text-primary mb-3 d-block"></i>
                    <h5 class="fw-semibold">Sign ข้อมูล</h5>
                    <p class="text-muted small mb-0">ลงลายเซ็นดิจิทัลบนข้อมูลหรือข้อความ</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a href="/Sign/PdfSign" class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm card-hover">
                <div class="card-body text-center py-4">
                    <i class="bi bi-file-earmark-pdf-fill fs-1 text-danger mb-3 d-block"></i>
                    <h5 class="fw-semibold">Sign PDF</h5>
                    <p class="text-muted small mb-0">ลงลายเซ็นดิจิทัลบนเอกสาร PDF</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a href="/Sign/Verify" class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm card-hover">
                <div class="card-body text-center py-4">
                    <i class="bi bi-patch-check-fill fs-1 text-success mb-3 d-block"></i>
                    <h5 class="fw-semibold">ตรวจสอบลายเซ็น</h5>
                    <p class="text-muted small mb-0">ตรวจสอบความถูกต้องของลายเซ็นดิจิทัล</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a href="/Sign/Audit" class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm card-hover">
                <div class="card-body text-center py-4">
                    <i class="bi bi-clock-history fs-1 text-warning mb-3 d-block"></i>
                    <h5 class="fw-semibold">ประวัติการ Sign</h5>
                    <p class="text-muted small mb-0">ดูประวัติการลงลายเซ็นทั้งหมด</p>
                </div>
            </div>
        </a>
    </div>

    <!-- User info -->
    <div class="col-12">
        <div class="alert alert-info mb-0">
            <i class="bi bi-person-circle"></i>
            ล็อกอินในชื่อ <strong>@ViewBag.User</strong> — ใช้ Windows SSO อัตโนมัติ
        </div>
    </div>
</div>
