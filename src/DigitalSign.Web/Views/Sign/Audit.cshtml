@model DigitalSign.Web.Models.AuditPagedResult
@{
    ViewData["Title"] = "Sign History";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-clock-history"></i> Digital Signature History</h4>
    <a href="/Sign" class="btn btn-primary btn-sm">
        <i class="bi bi-pen"></i> New Signature
    </a>
</div>

@if (Model == null || Model.Records.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No signature records found.
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Reference ID</th>
                            <th>Purpose</th>
                            <th>Department</th>
                            <th>Type</th>
                            <th>Date / Time</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Records)
                        {
                            <tr>
                                <td>
                                    <a href="/Sign/AuditDetail?referenceId=@r.ReferenceId"
                                       class="text-decoration-none fw-semibold">
                                        @r.ReferenceId
                                    </a>
                                </td>
                                <td>@r.Purpose</td>
                                <td>@r.Department</td>
                                <td><span class="badge bg-secondary">@r.SignatureType</span></td>
                                <td class="text-nowrap">
                                    @r.SignedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td>
                                    @if (r.IsRevoked)
                                    {
                                        <span class="badge bg-danger">Revoked</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Valid</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (Model.Pages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.Pages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" href="/Sign/Audit?page=@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }

    <div class="text-muted small mt-2">
        Showing @Model.Records.Count of @Model.Total records
    </div>
}
