@model DigitalSign.Web.Models.VerifyRequest
@{
    ViewData["Title"] = "Verify Signature";
    var result = ViewBag.VerifyResult as DigitalSign.Web.Models.VerifyResult;
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        @if (result != null)
        {
            <div class="alert @(result.IsOverallValid ? "alert-success" : "alert-danger") mb-4">
                <div class="d-flex align-items-center">
                    <i class="bi @(result.IsOverallValid ? "bi-patch-check-fill" : "bi-x-circle-fill") fs-4 me-3"></i>
                    <div>
                        <div class="fw-bold fs-5">
                            @(result.IsOverallValid ? "Signature is Valid ✓" : "Signature is Invalid ✗")
                        </div>
                        <small>
                            Signature: @(result.IsSignatureValid ? "✓ Valid" : "✗ Invalid") |
                            Certificate: @(result.IsCertificateValid ? "✓ Valid" : "✗ Expired") |
                            Signed by: @result.SignedBy |
                            Verified at: @result.VerifiedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")
                        </small>
                    </div>
                </div>
            </div>
        }

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-patch-check-fill"></i> Verify Digital Signature</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Verify" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="OriginalData" class="form-label fw-semibold">Original Data</label>
                            <textarea asp-for="OriginalData" class="form-control" rows="3"
                                      placeholder="Enter the original data that was signed..."></textarea>
                            <span asp-validation-for="OriginalData" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="SignatureBase64" class="form-label fw-semibold">Signature (Base64)</label>
                            <textarea asp-for="SignatureBase64" class="form-control font-monospace" rows="4"
                                      placeholder="Paste the Base64 signature here..."></textarea>
                            <span asp-validation-for="SignatureBase64" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="CertThumbprint" class="form-label fw-semibold">Certificate Thumbprint</label>
                            <input asp-for="CertThumbprint" class="form-control font-monospace"
                                   placeholder="Certificate Thumbprint..." />
                            <span asp-validation-for="CertThumbprint" class="text-danger small"></span>
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-patch-check"></i> Verify
                            </button>
                            <a href="/" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
