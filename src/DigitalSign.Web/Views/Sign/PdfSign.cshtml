@model DigitalSign.Web.Models.PdfSignRequest
@{
    ViewData["Title"] = "Sign PDF";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-file-earmark-pdf-fill"></i> ลงลายเซ็นบนเอกสาร PDF</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="PdfSign" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="PdfFile" class="form-label fw-semibold"></label>
                            <input asp-for="PdfFile" type="file" accept=".pdf"
                                   class="form-control" id="pdfFileInput" />
                            <div class="form-text">รองรับเฉพาะไฟล์ .pdf ขนาดสูงสุด 50MB</div>
                            <span asp-validation-for="PdfFile" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DocumentName" class="form-label fw-semibold"></label>
                            <input asp-for="DocumentName" class="form-control"
                                   placeholder="เช่น PurchaseOrder_2026" />
                            <span asp-validation-for="DocumentName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ReferenceId" class="form-label fw-semibold"></label>
                            <input asp-for="ReferenceId" class="form-control"
                                   placeholder="เช่น PO-2026-001" />
                            <span asp-validation-for="ReferenceId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Reason" class="form-label fw-semibold"></label>
                            <select asp-for="Reason" class="form-select">
                                <option value="Approved">อนุมัติ (Approved)</option>
                                <option value="Certified">รับรอง (Certified)</option>
                                <option value="Reviewed">ตรวจสอบ (Reviewed)</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Location" class="form-label fw-semibold"></label>
                            <input asp-for="Location" class="form-control" />
                        </div>

                        <div class="col-12">
                            <div class="alert alert-info small mb-0">
                                <i class="bi bi-info-circle"></i>
                                ลายเซ็นจะถูกวางที่มุมล่างซ้ายของหน้า @Model.SignaturePage
                                ขนาด @Model.SignatureWidth x @Model.SignatureHeight points
                            </div>
                        </div>

                        <div class="col-12 d-flex gap-2 align-items-center">
                            <button type="submit" class="btn btn-danger" id="btnSign">
                                <i class="bi bi-file-earmark-pen"></i> Sign PDF
                            </button>
                            <a href="/" class="btn btn-outline-secondary" id="btnCancel">
                                <i class="bi bi-arrow-left"></i> ยกเลิก
                            </a>
                            <div id="signProgress" class="d-none ms-2">
                                <div class="d-flex align-items-center gap-2 text-muted">
                                    <div class="spinner-border spinner-border-sm text-danger"></div>
                                    <span>กำลัง Sign PDF... <span id="progressSec">0</span> วินาที</span>
                                </div>
                                <div class="progress mt-1" style="height:4px;width:200px">
                                    <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated bg-danger" style="width:0%"></div>
                                </div>
                                <small class="text-muted">กระบวนการนี้ใช้เวลาประมาณ 10-15 วินาที</small>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
<script>
$('form').on('submit', function (e) {
    if (!$('#PdfFile')[0].files.length) return;

    const btn = $('#btnSign');
    btn.html('<i class="bi bi-hourglass-split"></i> กำลัง Sign...').prop('disabled', true);
    $('#btnCancel').prop('disabled', true);
    $('#signProgress').removeClass('d-none');

    // Progress timer
    let sec = 0;
    const maxSec = 120;
    const timer = setInterval(function () {
        sec++;
        $('#progressSec').text(sec);
        const pct = Math.min((sec / maxSec) * 100, 95);
        $('#progressBar').css('width', pct + '%');
    }, 1000);

    // เก็บ timer ไว้ clear ถ้าจำเป็น
    window._signTimer = timer;
});
</script>
}
