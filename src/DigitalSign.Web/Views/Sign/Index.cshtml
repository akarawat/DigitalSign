@model DigitalSign.Web.Models.SignRequest
@{
    ViewData["Title"] = "Sign Data";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-pen-fill"></i> Digital Signature — Sign Data</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Index" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="DataToSign" class="form-label fw-semibold">Data to Sign</label>
                            <textarea asp-for="DataToSign" class="form-control" rows="4"
                                      placeholder="Enter the data or text to sign..."></textarea>
                            <span asp-validation-for="DataToSign" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ReferenceId" class="form-label fw-semibold">Reference ID</label>
                            <input asp-for="ReferenceId" class="form-control"
                                   placeholder="e.g. PO-2026-001" />
                            <span asp-validation-for="ReferenceId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Purpose" class="form-label fw-semibold">Purpose</label>
                            <select asp-for="Purpose" class="form-select">
                                <option value="">-- Select Purpose --</option>
                                <option value="Approved">Approved</option>
                                <option value="Certified">Certified</option>
                                <option value="Reviewed">Reviewed</option>
                                <option value="Acknowledged">Acknowledged</option>
                            </select>
                            <span asp-validation-for="Purpose" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Department" class="form-label fw-semibold">Department</label>
                            <input asp-for="Department" class="form-control" placeholder="e.g. IT, HR, Finance" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Remarks" class="form-label fw-semibold">Remarks</label>
                            <input asp-for="Remarks" class="form-control" placeholder="Additional remarks (optional)" />
                        </div>

                        <div class="col-12 d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-pen"></i> Sign
                            </button>
                            <a href="/" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
